{
	"name": "saneprint",
	"version": "0.0.1",
	"type": "module",
	"description": "The official saneprint CLI",
	"author": "Karishma Garg",
	"license": "MIT",
	"keywords": [
		"nextjs",
		"react",
		"scaffolding",
		"cli",
		"architecture",
		"ai-governance"
	],
	"main": "dist/index.js",
	"bin": {
		"saneprint": "dist/index.js"
	},
	"publishConfig": {
		"access": "public"
	},
	"scripts": {
		"build": "tsup",
		"dev": "tsup --watch",
		"start": "node dist/index.js",
		"lint": "eslint src/**/*.ts"
	},
	"dependencies": {
		"commander": "^12.0.0",
		"@clack/prompts": "^0.7.0",
		"fs-extra": "^11.0.0",
		"chalk": "^5.0.0",
		"giget": "^1.2.0"
	},
	"devDependencies": {
		"@types/node": "^20.0.0",
		"@types/fs-extra": "^11.0.0",
		"typescript": "^5.0.0",
		"tsup": "^8.0.0"
	}
}
